# Azure SQL (ai-rag-db-1) — same as AiDecisionMakingBackend/db/.env
AZURE_SQL_SERVER=ai-rag-sql-server.database.windows.net
AZURE_SQL_PORT=1433
AZURE_SQL_DATABASE=ai-rag-db-1
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=
# AZURE_SQL_CONNECTION_STRING=

# Active bin calibration from build_quantile_bins / offline_bin_calibration
RISK_CALIBRATION_ID=00000000-0000-0000-0000-000000000001

# Azure Blob — account airagblob, container logistic
AZURE_STORAGE_ACCOUNT_NAME=airagblob
AZURE_STORAGE_ACCOUNT_KEY=
# Or: AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=airagblob;...

AZURE_STORAGE_CONTAINER=logistic
AZURE_STORAGE_BLOB_PREFIX=models
